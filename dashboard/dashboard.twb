      <aliases enabled='yes' />
      <column caption='Average Order Value (AOV)' datatype='real' name='[Calculation_2366923126175195137]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_amount]) / SUM([has_purchase])' />
      </column>
      <column caption='Discount Rate' datatype='real' name='[Calculation_2366923126175264770]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([discount_amount]) / SUM([gross_amount])' />
      </column>
      <column caption='Gross Margin Proxy' datatype='real' name='[Calculation_2366923126175645699]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([margin_proxy]) / SUM([net_amount])' />
      </column>
      <column caption='Repeat Purchase Rate' datatype='real' name='[Calculation_2366923126175760388]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([repeat_rate_flag]) / COUNTD([user_id])' />
      </column>
      <column caption='Efficiency- Funnel to step conversions' datatype='real' name='[Calculation_2366923126175940613]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_begin_checkout]) / SUM([has_add_to_cart])' />
      </column>
      <column caption='Payment failure rate' datatype='real' name='[Calculation_2366923126176280582]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (SUM([has_purchase]) / SUM([has_payment_attempt]))' />
      </column>
      <column caption='CCR (Checkout Completion Rate)' datatype='real' name='[Calculation_2366923126179913735]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_purchase]) / SUM([has_begin_checkout])' />
      </column>
      <column caption='Session CVR' datatype='real' name='[Calculation_2366923126180081672]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([has_purchase]) / COUNTD([session_id])' />
      </column>
      <column caption='RPES (Revenue per Session)' datatype='real' name='[Calculation_2366923126181556234]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([net_amount]) / COUNT([session_id])' />
      </column>
      <column caption='CCR Lift %' datatype='real' name='[Calculation_2366923126196924431]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(LOOKUP([Calculation_2366923126179913735], 0)) - ZN(LOOKUP([Calculation_2366923126179913735], -1))) / ABS(ZN(LOOKUP([Calculation_2366923126179913735], -1)))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Segment Lift' datatype='real' name='[Calculation_2366923126294712357]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ZN(LOOKUP(IF ATTR([variant]) = &apos;b&apos; THEN [Calculation_2366923126181556234] END, 0)) / ZN(LOOKUP(IF ATTR([variant]) = &apos;a&apos; THEN [Calculation_2366923126181556234] END, 0))) - 1'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='User count' datatype='integer' name='[Calculation_2366923126301495335]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNTD([user_id])' />
