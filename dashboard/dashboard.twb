            <column caption='Duration: Cart' datatype='real' name='[Calculation_2366923126286147617]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MEDIAN([time_to_cart_sec])' />
            </column>
            <column caption='Duration: Checkout' datatype='real' name='[Calculation_2366923126286245922]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='MEDIAN([time_to_checkout_sec]) - MEDIAN([time_to_cart_sec])' />
