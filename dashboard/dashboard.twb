    <worksheet name='Segment deep dive'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontcolor='#4e79a7' fontname='Times New Roman' fontsize='16'>Growth Opportunity: Search Segment Performance</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Checkout_Master_ETL' name='federated.0zuci3u0xxpv9g10l09xr0a8x0rc' />
          </datasources>
          <datasource-dependencies datasource='federated.0zuci3u0xxpv9g10l09xr0a8x0rc'>
            <column caption='Session CVR' datatype='real' name='[Calculation_2366923126180081672]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([has_purchase]) / COUNTD([session_id])' />
            </column>
            <column caption='RPES (Revenue per Session)' datatype='real' name='[Calculation_2366923126181556234]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([net_amount]) / COUNT([session_id])' />
            </column>
            <column caption='Channel' datatype='string' name='[channel]' role='dimension' type='nominal' />
            <column aggregation='Sum' caption='City Tier' datatype='integer' name='[city_tier]' role='dimension' type='ordinal' />
            <column caption='Device' datatype='string' name='[device]' role='dimension' type='nominal' />
            <column caption='Has Purchase' datatype='integer' name='[has_purchase]' role='measure' type='quantitative' />
            <column aggregation='Sum' caption='Is New User' datatype='integer' name='[is_new_user]' role='dimension' type='ordinal' />
            <column caption='Net Amount' datatype='real' name='[net_amount]' role='measure' type='quantitative' />
            <column-instance column='[channel]' derivation='None' name='[none:channel:nk]' pivot='key' type='nominal' />
            <column-instance column='[city_tier]' derivation='None' name='[none:city_tier:ok]' pivot='key' type='ordinal' />
            <column-instance column='[device]' derivation='None' name='[none:device:nk]' pivot='key' type='nominal' />
