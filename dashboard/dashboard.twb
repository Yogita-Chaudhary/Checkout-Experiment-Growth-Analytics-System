      <column caption='Funnel negative' datatype='integer' name='[Calculation_2366923126225842196]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-[Pivot Field Values]' />
      </column>
      <column caption='Drop off %' datatype='real' name='[Calculation_2366923126227955733]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='1 - (ZN(SUM([Pivot Field Values])) / LOOKUP(ZN(SUM([Pivot Field Values])), -1))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Speed Penalty %' datatype='real' name='[Calculation_2366923126278553631]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(MEDIAN(IF [variant] = &apos;b&apos; THEN [time_to_purchase_sec] END) / MEDIAN(IF [variant] = &apos;a&apos; THEN [time_to_purchase_sec] END)) - 1' />
      </column>
      <column caption='Funnel Lift %' datatype='real' name='[Calculation_2366923126280974368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='( { FIXED [Pivot Field Names] : SUM(IF [variant] = &apos;b&apos; THEN [Pivot Field Values] END) } / { FIXED [Pivot Field Names] : SUM(IF [variant] = &apos;a&apos; THEN [Pivot Field Values] END) } ) - 1' />
      </column>
      <column caption='Duration: Cart' datatype='real' name='[Calculation_2366923126286147617]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([time_to_cart_sec])' />
      </column>
      <column caption='Duration: Checkout' datatype='real' name='[Calculation_2366923126286245922]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([time_to_checkout_sec]) - MEDIAN([time_to_cart_sec])' />
      </column>
      <column caption='Duration: Purchase' datatype='real' name='[Calculation_2366923126286340131]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MEDIAN([time_to_purchase_sec]) - MEDIAN([time_to_checkout_sec])' />
      </column>
